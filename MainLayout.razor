@inherits LayoutComponentBase

<div class="min-h-screen flex flex-col">
    <header class="bg-white shadow-sm border-b border-slate-200 py-4 px-6 flex justify-between items-center">
        <h1 class="text-xl font-bold text-blue-600 tracking-tight">QMS</h1>
        <nav class="flex gap-4 items-center">
            <NavLink class="text-sm font-medium text-slate-600 hover:text-blue-600" href="/" Match="NavLinkMatch.All">Home</NavLink>
            <NavLink class="text-sm font-medium text-slate-600 hover:text-blue-600" href="/queue">Queue</NavLink>
            <NavLink class="text-sm font-medium text-slate-600 hover:text-blue-600" href="/display">Display</NavLink>
            <NavLink class="text-sm font-medium text-slate-600 hover:text-blue-600" href="/counter">Counter</NavLink>
            <NavLink class="text-sm font-medium text-slate-600 hover:text-blue-600" href="/admin">Admin</NavLink>
        </nav>
    </header>

    <main class="flex-grow p-6">
        <ErrorBoundary @ref="errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <div class="p-8 bg-rose-50 border border-rose-200 rounded-3xl text-rose-800">
                    <h2 class="text-xl font-bold mb-2">Something went wrong</h2>
                    <p class="text-sm mb-4">@ex.Message</p>
                    <button class="px-4 py-2 bg-rose-600 text-white rounded-xl text-sm" @onclick="() => errorBoundary?.Recover()">
                        Try again
                    </button>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </main>

    <footer class="bg-white border-t border-slate-200 py-3 px-6 text-center text-xs text-slate-400">
        &copy; 2026 Queue Management System
    </footer>
</div>

@code {
    private ErrorBoundary? errorBoundary;

    protected override void OnInitialized()
    {
        Console.WriteLine("Blazor MainLayout Initialized!");
    }

    protected override void OnParametersSet()
    {
        errorBoundary?.Recover();
    }
}
