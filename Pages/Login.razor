@page "/login"
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="max-w-md mx-auto mt-20 p-8 bg-white rounded-3xl shadow-xl border border-slate-100">
    <div class="text-center mb-8">
        <h2 class="text-2xl font-bold text-slate-900">Sign In</h2>
        <p class="text-slate-500 text-sm">Access the secure management portal</p>
    </div>

    <div class="space-y-4">
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Username</label>
            <input @bind="username" type="text" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-none" placeholder="Enter username" />
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Password</label>
            <input @bind="password" type="password" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-none" placeholder="••••••••" />
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <p class="text-rose-500 text-sm bg-rose-50 p-3 rounded-lg border border-rose-100">@error</p>
        }

        <button @onclick="HandleLogin" class="w-full py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl shadow-lg shadow-blue-200 transition-all active:scale-95">
            Log In
        </button>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string error = "";

    private void HandleLogin()
    {
        var user = AuthManager.Login(username, password);
        if (user != null)
        {
            SessionState.CurrentUser = user;
            var returnUrl = Nav.QueryString("returnUrl") ?? "/";
            Nav.NavigateTo(returnUrl);
        }
        else
        {
            error = "Invalid username or password.";
        }
    }
}
