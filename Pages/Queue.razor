@using System.Timers
@page "/queue"

<div class="max-w-2xl mx-auto py-12">
    <div class="bg-white rounded-[2.5rem] shadow-2xl shadow-blue-100 border border-slate-100 overflow-hidden">
        <div class="bg-blue-600 p-10 text-center text-white">
            <h2 class="text-4xl font-black tracking-tight mb-2">Welcome</h2>
            <p class="text-blue-100 font-medium">Please enter your details to get a ticket</p>
        </div>
        
        <div class="p-12">
            @if (showFlash)
            {
                <div class="mb-8 p-8 bg-green-50 border-2 border-green-200 rounded-3xl text-center animate-bounce-in">
                    <p class="text-green-800 text-xl font-bold">Hi @customerName!</p>
                    <p class="text-green-600 text-lg">Your ticket is <span class="text-4xl font-black">#@lastTicket</span></p>
                </div>
            }
            else
            {
                <div class="space-y-6 max-w-sm mx-auto">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Your Name</label>
                        <input @bind="customerName" type="text" class="w-full px-6 py-4 rounded-2xl border-2 border-slate-100 focus:border-blue-500 outline-none transition-all text-lg" placeholder="John Doe" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Phone Number</label>
                        <input @bind="customerPhone" type="tel" class="w-full px-6 py-4 rounded-2xl border-2 border-slate-100 focus:border-blue-500 outline-none transition-all text-lg" placeholder="0123456789" />
                    </div>

                    <button @onclick="GetTicket" disabled="@(string.IsNullOrWhiteSpace(customerName))" class="w-full py-6 bg-blue-600 hover:bg-blue-700 disabled:bg-slate-300 text-white rounded-3xl font-black text-2xl shadow-xl shadow-blue-100 transition-all active:scale-95 flex items-center justify-center gap-3">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                        GET TICKET
                    </button>
                </div>
            }
            
            @if (globalLastTicket > 0)
            {
                <div class="mt-8 text-center text-slate-500 font-bold">
                    Last issued ticket: <span class="text-slate-800">#@globalLastTicket</span>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string customerName = "";
    private string customerPhone = "";
    private int lastTicket = 0;
    private static int globalLastTicket = 0;
    private bool showFlash = false;
    private Timer? timer;

    private void GetTicket()
    {
        if (!string.IsNullOrWhiteSpace(customerName))
        {
            lastTicket = QueueManager.GenerateTicket(customerName, customerPhone);
            globalLastTicket = lastTicket;
            showFlash = true;
            
            timer = new Timer(3000);
            timer.Elapsed += (s, e) => {
                ResetForm();
                InvokeAsync(StateHasChanged);
                timer?.Dispose();
                timer = null;
            };
            timer.AutoReset = false;
            timer.Start();
        }
    }

    private void ResetForm()
    {
        customerName = "";
        customerPhone = "";
        lastTicket = 0;
        showFlash = false;
    }
}


<style>
    .animate-bounce-in {
        animation: bounceIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    @@keyframes bounceIn {
        from { opacity: 0; transform: scale(0.8); }
        to { opacity: 1; transform: scale(1); }
    }
</style>
